# ============================================================================
# Vibe Coder Hub — Environment variables (canonical list)
# ============================================================================
# Copy to .env.local for local dev. Vercel env vars set via dashboard.
# Every variable validated by lib/env.ts at boot via Zod.
# Missing or invalid required var → app fails to start with a clear error.
# ============================================================================

# ── PUBLIC (ships to browser via NEXT_PUBLIC_ prefix) ───────────────────────
# Never put a server-only secret behind NEXT_PUBLIC_; it WILL ship to the client.

NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
NEXT_PUBLIC_POSTHOG_KEY=phc_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_SENTRY_DSN=

# ── SUPABASE (server-only) ──────────────────────────────────────────────────

SUPABASE_SERVICE_ROLE_KEY=eyJ...
DATABASE_URL_POOLED=postgresql://postgres.<ref>:<pwd>@aws-0-us-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true
DATABASE_URL_DIRECT=postgresql://postgres:<pwd>@db.<ref>.supabase.co:5432/postgres

# ── AUTH (admin allow-list) ─────────────────────────────────────────────────
# Comma-separated GitHub user IDs (numeric, tamper-proof). Per Q2.6 ruling.
# Get yours via: curl https://api.github.com/users/<your-handle>
ADMIN_GITHUB_USER_IDS=

# ── STRIPE ──────────────────────────────────────────────────────────────────

STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID_PRO_YEARLY=price_...

# ── RESEND ──────────────────────────────────────────────────────────────────

RESEND_API_KEY=re_...
RESEND_FROM_TRANSACTIONAL=notify@vibecoderhub.com
RESEND_FROM_NEWSLETTER=news@vibecoderhub.com
RESEND_WEBHOOK_SECRET=

# ── OPENAI (embeddings only — text-embedding-3-small) ───────────────────────

OPENAI_API_KEY=sk-...
OPENAI_EMBEDDINGS_MONTHLY_BUDGET_USD=50

# ── REPLICATE (NSFW pre-screen for avatars) ─────────────────────────────────

REPLICATE_API_TOKEN=r8_...

# ── CLOUDFLARE R2 (raw ingestion dumps) ─────────────────────────────────────

R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=vch-raw-dumps
R2_PUBLIC_URL=

# ── GITHUB (ingestion) ──────────────────────────────────────────────────────
# PAT with scopes: repo, read:org, read:user

GITHUB_INGESTION_TOKEN=ghp_...

# ── SENTRY ──────────────────────────────────────────────────────────────────

SENTRY_AUTH_TOKEN=
SENTRY_ORG=vibecoderhub
SENTRY_PROJECT=vibecoderhub-web

# ── POSTHOG (server-side captures) ──────────────────────────────────────────

POSTHOG_API_KEY=phc_...

# ── OPS ─────────────────────────────────────────────────────────────────────

SLACK_OPS_WEBHOOK_URL=https://hooks.slack.com/services/...

# ── RUNTIME ─────────────────────────────────────────────────────────────────

NODE_ENV=development
LOG_LEVEL=debug
VCH_ENV=local

# Auto-populated by Vercel; used for Sentry release tagging.
# Leave blank locally; Vercel injects on deploy.
VERCEL_GIT_COMMIT_SHA=

# ============================================================================
# LOCAL-DEV "no external services" mode
# ============================================================================
# For local dev without external accounts wired up, set these placeholders:
#
#   NEXT_PUBLIC_SUPABASE_URL=http://localhost:54321
#   NEXT_PUBLIC_SUPABASE_ANON_KEY=<from `supabase start` output>
#   SUPABASE_SERVICE_ROLE_KEY=<from `supabase start` output>
#   DATABASE_URL_POOLED=postgresql://postgres:postgres@localhost:54322/postgres
#   DATABASE_URL_DIRECT=postgresql://postgres:postgres@localhost:54322/postgres
#   ADMIN_GITHUB_USER_IDS=<your GitHub numeric ID>
#
#   STRIPE_SECRET_KEY=sk_test_dummy
#   STRIPE_WEBHOOK_SECRET=whsec_dummy
#   STRIPE_PRICE_ID_PRO_YEARLY=price_dummy
#
#   RESEND_API_KEY=re_dummy
#   RESEND_WEBHOOK_SECRET=dummy
#
#   OPENAI_API_KEY=sk-dummy
#   REPLICATE_API_TOKEN=r8_dummy
#
#   R2_ACCOUNT_ID=dummy
#   R2_ACCESS_KEY_ID=dummy
#   R2_SECRET_ACCESS_KEY=dummy
#
#   GITHUB_INGESTION_TOKEN=ghp_dummy
#
#   NEXT_PUBLIC_POSTHOG_KEY=phc_dummy
#   POSTHOG_API_KEY=phc_dummy
#
#   NEXT_PUBLIC_SENTRY_DSN=
#   SENTRY_AUTH_TOKEN=
#
#   SLACK_OPS_WEBHOOK_URL=
#
# In local-dev mode, lib/env.ts validates schema but the validators for keys
# starting with a known dummy prefix (sk_test_dummy, whsec_dummy, etc.) skip
# external service calls and return mocked responses. Real services wire in
# slice-by-slice as needed.
